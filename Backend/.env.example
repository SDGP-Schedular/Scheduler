# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=your-super-secret-key-change-this-in-production

# Firebase Configuration
# Path to your Firebase Admin SDK service account JSON file
# Download from: Firebase Console -> Project Settings -> Service accounts -> Generate new private key
FIREBASE_SERVICE_ACCOUNT_PATH=serviceAccountKey.json
# Optional (recommended): explicit Firebase project id
FIREBASE_PROJECT_ID=your-firebase-project-id
# Optional for cloud hosting (when file path is not available): full JSON string of service account
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Google Gemini API Key (required for AI quiz generation)
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# CORS - Allowed origins (comma-separated for multiple)
CORS_ORIGINS=https://app.scheduler.it.com,http://localhost:5173,http://localhost:3000

# Server Port
PORT=5000
